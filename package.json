{
  "name": "scctl",
  "version": "1.0.0",
  "type": "module",
  "description": "Bridge SuperCollider sclang to AI agents via MCP and CLI",
  "bin": {
    "scctl": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "supercollider",
    "sclang",
    "mcp",
    "model-context-protocol",
    "audio",
    "synthesis",
    "ai-agent"
  ],
  "author": "Jerry Duan",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bayern99/supercollider-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Bayern99/supercollider-mcp/issues"
  },
  "homepage": "https://github.com/Bayern99/supercollider-mcp#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.8"
  }
}
